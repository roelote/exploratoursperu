# --- WordPress Backend ---

# URL base del backend WordPress (DEBE incluir barra final /)
# Desarrollo:  http://web.exploratours/
# Producción:  https://www.tudominio.com/
WP_DOMAIN=http://web.exploratours/

# --- Sitio Astro ---

# URL pública del sitio Astro (sin barra final)
# Desarrollo:  http://localhost:4321
# Producción:  https://www.tudominio.com
PUBLIC_SITE_URL=http://localhost:4321
