---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";
import "@fortawesome/fontawesome-free/css/all.min.css";

// ── Tipos Yoast ───────────────────────────────────────────────────────────────
type YoastRobots = {
  index?: string;
  follow?: string;
  "max-snippet"?: string;
  "max-image-preview"?: string;
  "max-video-preview"?: string;
};

type YoastOgImage = {
  url: string;
  width?: number;
  height?: number;
  type?: string;
};

type YoastSeo = {
  title?: string;
  description?: string;
  robots?: YoastRobots;
  og_locale?: string;
  og_type?: string;
  og_title?: string;
  og_description?: string;
  og_url?: string;
  og_site_name?: string;
  og_image?: YoastOgImage[];
  twitter_card?: string;
  twitter_title?: string;
  twitter_description?: string;
  twitter_image?: string;
  article_modified_time?: string;
  article_published_time?: string;
};

interface Props {
  title?: string;
  altLangUrl?: string | null;
  seo?: YoastSeo | null;
}

const { title, altLangUrl, seo } = Astro.props;

/**
 * aqui estoy definiendo el dominio base del sitio
 */
const envSiteUrl = import.meta.env.PUBLIC_SITE_URL;
const siteUrl = envSiteUrl 
  ? envSiteUrl.replace(/\/$/, "") 
  : Astro.url.origin; // Si falla el .env, usa el dominio actual detectado

const lang = Astro.currentLocale ?? "es";
const isEn = lang === "en";

// 2. OBTENER EL PATHNAME (Ej: /tours-en-cusco)
const pathname = Astro.url.pathname; 

// 3. LÓGICA DE PATH ALTERNO (Traducción)
const computedAltPath: string | null = altLangUrl === null 
  ? null 
  : (altLangUrl ?? (isEn ? pathname.replace(/^\/en/, "") || "/" : `/en${pathname === '/' ? '' : pathname}`));

// 4. CONSTRUCCIÓN DE URLs ABSOLUTAS (Obligatorio para SEO)
// Nos aseguramos de que siempre empiecen con el protocolo (http/https)
const esFullUrl = isEn 
  ? (computedAltPath !== null ? siteUrl + computedAltPath : null) 
  : siteUrl + (pathname === '/en' ? '/' : pathname);

const enFullUrl = isEn 
  ? siteUrl + pathname 
  : (computedAltPath !== null ? siteUrl + computedAltPath : null);

const canonicalUrl = siteUrl + pathname;


// ── Campos SEO desde Yoast ────────────────────────────────────────────────────
const pageTitle = seo?.title ?? title ?? "Explora Tours Peru";
const metaDesc = seo?.description ?? null;
const ogTitle = seo?.og_title ?? seo?.title ?? pageTitle;
const ogDesc = seo?.og_description ?? seo?.description ?? null;
const ogImage = seo?.og_image?.[0]?.url ?? null;
const ogImageW = seo?.og_image?.[0]?.width ?? null;
const ogImageH = seo?.og_image?.[0]?.height ?? null;
const ogType = seo?.og_type ?? "website";
const ogLocale = seo?.og_locale ?? (isEn ? "en_US" : "es_ES");
const twCard = seo?.twitter_card ?? "summary_large_image";
const twTitle = seo?.twitter_title ?? ogTitle;
const twDesc = seo?.twitter_description ?? ogDesc;
const twImage = seo?.twitter_image ?? ogImage;
const articleModTime = seo?.article_modified_time ?? null;
const articlePubTime = seo?.article_published_time ?? null;

const robotsContent = seo?.robots ? Object.values(seo.robots).filter(Boolean).join(", ") : null;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    {favicon ? (
      <link rel="icon" href={favicon} />
    ) : (
      <>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
      </>
    )}
    <title>{pageTitle}</title>
    
    <slot name="head"/>

    {metaDesc && <meta name="description" content={metaDesc} />}
    {robotsContent && <meta name="robots" content={robotsContent} />}
    
    <link rel="canonical" href={canonicalUrl} />
    
    {esFullUrl && <link rel="alternate" hreflang="es" href={esFullUrl} />}
    {enFullUrl && <link rel="alternate" hreflang="en" href={enFullUrl} />}
    {esFullUrl && <link rel="alternate" hreflang="x-default" href={esFullUrl} />}

    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={ogTitle} />
    {ogDesc && <meta property="og:description" content={ogDesc} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImageW && <meta property="og:image:width" content={String(ogImageW)} />}
    {ogImageH && <meta property="og:image:height" content={String(ogImageH)} />}
    {articleModTime && <meta property="article:modified_time" content={articleModTime} />}
    {articlePubTime && <meta property="article:published_time" content={articlePubTime} />}

    <meta name="twitter:card" content={twCard} />
    <meta name="twitter:title" content={twTitle} />
    {twDesc && <meta name="twitter:description" content={twDesc} />}
    {twImage && <meta name="twitter:image" content={twImage} />}

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@26.7.6/build/css/intlTelInput.css" />
  </head>
  <body>
    <Header altLangUrl={computedAltPath} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>