---
import type { GetStaticPaths } from "astro";
import MainLayout from "../layouts/MainLayout.astro";
import { getInfoPage, getInfoPageBySlug } from "../libs/wp";

const { slug } = Astro.params;

export const getStaticPaths: GetStaticPaths = async () => {
  const dataPage = await getInfoPage();

  const excluded = ["contacto", "blog"];
  
  return dataPage
  .filter((page:any) => !excluded.includes(page.slug))
  .map((page: any) => ({
    params: { slug: page.slug },
  }));
};

const [data] = await getInfoPageBySlug(slug);
---

<MainLayout>
  <main>
    <div class="w-full h-full py-10">
      <div set:html={data.content.rendered} />
    </div>
  </main>
</MainLayout>
