      <div class="w-full relative">
        <Image src={dataHome?.featured_img} width={1920} height={1080} loading="eager" fetchpriority="high" quality={80} format="webp" sizes="100vw" class="w-full h-[90vh] object-cover object-center" alt="" />
        <div class="bg-black/50 absolute inset-0 w-full h-full z-10"></div>
