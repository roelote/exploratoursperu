---
import MainLayout from "../../../layouts/MainLayout.astro";
import { getPosts, getSidebarBlog } from "../../../libs/wp";

const sidebar = await getSidebarBlog('en');
const allPosts = await getPosts('en');

export async function getStaticPaths() {
  const allPosts = await getPosts('en');

  return allPosts.map((post: any) => {
    const esSlug: string | null = post.wpml_translations?.es?.slug ?? null;
    return {
      params: { slug: post.slug },
      props: { post, altLangUrl: esSlug ? `/blog/${esSlug}` : null },
    };
  });
}

const { post, altLangUrl } = Astro.props as { post: any; altLangUrl: string | null };
const blogs = allPosts.slice(0, 5);

function getDateFormatter(date: any) {
  return new Date(date).toLocaleDateString("es-ES", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
}
---

<MainLayout altLangUrl={altLangUrl} seo={post?.yoast_head_json}>
  <main>
    <section>
      <div class="container">
        <div class="my-5">
          <div class="flex items-start flex-col xl:flex-row justify-between gap-10">
            <div class="w-full">
              <div class="w-full h-[530px] overflow-hidden">
                <img decoding="async" fetchpriority="high" draggable="false" class="w-full h-full object-cover object-center rounded-[20px]" src={post.featured_image.full} alt="" />
              </div>
              <div class="wrapper-post">
                <div class="mt-5 shadow-[0px_0px_30px_0px_rgba(0,0,0,0.1)] p-5 rounded-[20px] overflow-hidden">
                  <div class="w-full flex items-center justify-start gap-3 mb-3">
                    <div class="py-2.5 px-5 bg-green/20 text-center rounded-lg group hover:bg-green transition-colors duration-300 cursor-pointer select-none">
                      <p class="flex items-center gap-1 mb-0!">
                        <i class="fa-solid fa-user text-green group-hover:text-white"></i>
                        <span class="text-sm text-green group-hover:text-white">Explora Tours</span>
                      </p>
                    </div>
                    <div>
                        <span class="size-2 bg-yellow block rounded-full"></span>
                    </div>
                    <div class="py-2.5 px-5 bg-green/20 text-center rounded-lg group hover:bg-green transition-colors duration-300 cursor-pointer select-none">
                      <p class="flex items-center gap-1 mb-0!">
                        <i class="fa-solid fa-hourglass-end text-green group-hover:text-white"></i>
                        <span class="text-sm text-green group-hover:text-white">{post.reading_time.minutes} min de lectura</span>
                      </p>
                    </div>
                    <div>
                        <span class="size-2 bg-yellow block rounded-full"></span>
                    </div>
                    <div class="py-2.5 px-5 bg-green/20 text-center rounded-lg group hover:bg-green transition-colors duration-300 cursor-pointer select-none">
                      <p class="flex items-center gap-1 mb-0!">
                        <i class="fa-solid fa-calendar text-green group-hover:text-white"></i>
                        <span class="text-sm text-green group-hover:text-white">{getDateFormatter(post.date)}</span>
                      </p>
                    </div>
                  </div>
                  <h1 class="font-semibold text-3xl">{post.title.rendered}</h1>
                  <p set:html={post.content.rendered} />
                </div>
              </div>
            </div>
            <div class="w-full lg:w-1/3 sticky top-2 right-0">
              <div class="w-full shadow-[0px_0px_30px_0px_rgba(0,0,0,0.1)] p-5 rounded-[20px] overflow-hidden">
                <div set:html={sidebar?.content} />
                <h3>Recent Posts</h3>
                <div class="flex flex-col gap-3">
                  {
                    blogs.map((last: any) => (
                      <a href={`${last.slug}`} title={last.title.rendered} >
                        <div class="flex items-center justify-between gap-2">
                          <div class="w-[80px] min-w-[80px] h-[80px]">
                            <img decoding="async" fetchpriority="high" class="w-full h-full object-cover object-center rounded-lg" src={last.featured_image.thumbnail} alt="" />
                          </div>
                          <div class="w-full">
                            <p class="text-base! mb-0! font-semibold line-clamp-2">{last.title.rendered}</p>
                            <p class="text-sm mb-0! flex items-center gap-1">
                              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <>
                                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                  <path d="M4 7a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2v-12" />
                                  <path d="M16 3v4" />
                                  <path d="M8 3v4" />
                                  <path d="M4 11h16" />
                                  <path d="M8 14v4" />
                                  <path d="M12 14v4" />
                                  <path d="M16 14v4" />
                                </>
                              </svg>{" "}
                              {getDateFormatter(last.date)}
                            </p>
                          </div>
                        </div>
                      </a>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</MainLayout>
