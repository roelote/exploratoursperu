---
import Image from "astro/components/Image.astro";
const { data } = Astro.props;
const pathname = Astro.url.pathname;
---

<section>
  <div class="w-full relative">
    <Image src={data} width={1920} height={1080} loading="eager" fetchpriority="high" quality={80} format="webp" sizes="100vw" class="w-full h-[90vh] object-cover object-center" alt="Explore Tours Peru" />

    <div class="bg-black/50 absolute inset-0 w-full h-full z-10"></div>
    <div class="w-full lg:w-248.75 absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 z-20 px-5 md:px-0 despues">
      {
            pathname === "/en/" || pathname === "/en"
            ? <h1 class="text-4xl text-balance text-white font-bold tracking-widest text-center uppercase">
            Discover <span class="text-yellow">authentic local tours</span> and <span class="text-yellow">tailor-made adventures</span> in the Andes
            </h1>
            <p class="text-white! text-center inline-block my-5 text-base">
                Turn your dream trip into reality. We explore the wonders of Machu Picchu and the best-kept secrets of our land with the support of true local experts. We design safe and memorable experiences; your next great story starts here.
            </p>
            <div class="flex flex-col md:flex-row items-center justify-center gap-5">
                <a href="#" class="w-full md:w-80 text-center bg-yellow capitalize py-3 inline-block text-black font-medium border-2 border-yellow hover:bg-transparent hover:text-white transition-all">Book the Inca Trail 2026</a>
                <a href="#" class="w-full md:w-80 text-center bg-transparend border-2 border-yellow capitalize py-3 inline-block font-medium text-white hover:bg-yellow hover:text-black transition-all">Explore Our Tours</a>
            </div>

                : <h1 class="text-4xl text-balance text-white font-bold tracking-widest text-center uppercase">
            Descubre auténticos <span class="text-yellow">tours locales</span> y <span class="text-yellow">aventuras a Medida</span> en los Andes
          </h1>
          <p class="text-white! text-center inline-block my-5 text-base">
            Convierte tu viaje soñado en realidad. Exploramos las maravillas de Machu Picchu y los secretos mejor guardados de nuestra tierra con el respaldo de verdaderos expertos locales. Diseñamos experiencias seguras y memorables; tu próxima gran historia comienza aquí.
          </p>
          <div class="flex flex-col md:flex-row items-center justify-center gap-5">
            <a href="#" class="w-full md:w-80 text-center bg-yellow capitalize py-3 inline-block text-black font-medium border-2 border-yellow hover:bg-transparent hover:text-white transition-all">Reserva el Camino Inca 2026</a>
            <a href="#" class="w-full md:w-80 text-center bg-transparend border-2 border-yellow capitalize py-3 inline-block font-medium text-white hover:bg-yellow hover:text-black transition-all">Explora Nuestros Tours</a>
          </div>
            }
    </div>
    <div class="absolute bottom-0 left-0 w-full z-30">
      <svg width="100%" height="50px" class="-scale-y-100" fill="#ffffff" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100" preserveAspectRatio="none">
        <path class="elementor-shape-fill" opacity="0.33" d="M473,67.3c-203.9,88.3-263.1-34-320.3,0C66,119.1,0,59.7,0,59.7V0h1000v59.7 c0,0-62.1,26.1-94.9,29.3c-32.8,3.3-62.8-12.3-75.8-22.1C806,49.6,745.3,8.7,694.9,4.7S492.4,59,473,67.3z"></path>
        <path class="elementor-shape-fill" opacity="0.66" d="M734,67.3c-45.5,0-77.2-23.2-129.1-39.1c-28.6-8.7-150.3-10.1-254,39.1 s-91.7-34.4-149.2,0C115.7,118.3,0,39.8,0,39.8V0h1000v36.5c0,0-28.2-18.5-92.1-18.5C810.2,18.1,775.7,67.3,734,67.3z"></path>
        <path class="elementor-shape-fill" d="M766.1,28.9c-200-57.5-266,65.5-395.1,19.5C242,1.8,242,5.4,184.8,20.6C128,35.8,132.3,44.9,89.9,52.5C28.6,63.7,0,0,0,0 h1000c0,0-9.9,40.9-83.6,48.1S829.6,47,766.1,28.9z"></path>
      </svg>
    </div>
  </div>
</section>
