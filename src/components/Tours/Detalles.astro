---
import { getImages } from "../../libs/wp";
const { details } = Astro.props;
const data = details?.detalles || []

const imgs = data?.map((url:any)=> (getImages(url.img)))

const dataImg = await Promise.all(imgs);
---

{
  data?.map((d:any, index:number) => (
    <div class="flex gap-3 items-center">
      <div>
        <span class="size-12 bg-green rounded-full flex items-center justify-center">
          <img class="size-7" decoding="async" src={dataImg[index]?.url} alt="" />
        </span>
      </div>
      <div class="flex flex-col justify-start">
        <span class="font-semibold text-sm md:text-base">{d.titulo}</span>
        <span class="font-normal text-sm text-wrap md:text-nowrap capitalize">{d.descripcion}</span>
      </div>
    </div>
  ))
}