---
const { content, price } = Astro.props;
const precio = price.precio
---

<div class="sidebar-tour-page" id="content-form-contact">
  <div class="flex items-center justify-between">
    <div>
      <p class="text-parragraph text-sm font-medium mb-0!">Precio</p>
      <p class="text-lg font-bold text-black! mb-0!">Desde</p>
    </div>
    <div>
      <span class="text-4xl font-bold text-black">$ {precio}</span>
    </div>
  </div>
  <div set:html={content} id="cf7-container" />
</div>

<script src="https://cdn.jsdelivr.net/npm/intl-tel-input@26.7.6/build/js/intlTelInput.min.js"></script>

<script>
window.addEventListener("load", () => {

  const container = document.getElementById("cf7-container");
  if (!container) return;

  const form = container.querySelector("form");
  if (!form) return;

  const phoneInput = form.querySelector("#phone");
  const submitBtn = form.querySelector('input[type="submit"]');
  const hiddenPhone = form.querySelector('input[name="telefono-completo"]');

  if (!phoneInput) return;

  const iti = window.intlTelInput(phoneInput, {
    loadUtils: () =>
      import("https://cdn.jsdelivr.net/npm/intl-tel-input@26.7.6/build/js/utils.js"),
    initialCountry: "auto",
    geoIpLookup: (callback) => {
      fetch("https://ipapi.co/json")
        .then((res) => res.json())
        .then((data) => callback(data.country_code))
        .catch(() => callback("us"));
    }
  });

  // loader
  const loader = document.createElement("div");
  loader.className = "form-loading";
  loader.innerHTML = `
    <div class="loading-spinner"></div>
    <span>Enviando mensaje...</span>
  `;
  submitBtn.parentNode.appendChild(loader);

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    // 1. Obtener datos del formulario
    const formData = new FormData(form);
    
    // 2. NUEVA VALIDACIÓN: Verificar si todos los campos están vacíos
    let isAllEmpty = true;
    for (let value of formData.values()) {
      if (value.toString().trim() !== "") {
        isAllEmpty = false;
        break;
      }
    }

    if (isAllEmpty) {
      alert("Por favor, completa al menos un campo antes de enviar.");
      return; // Detiene la ejecución aquí
    }

    // Si pasa la validación, procedemos
    loader.classList.add("active");
    submitBtn.disabled = true;

    // guardar telefono completo
    if (hiddenPhone) {
      hiddenPhone.value = iti.getNumber();
    }

    // Actualizamos el formData con el teléfono completo si es necesario
    formData.set("telefono-completo", iti.getNumber());

    try {
      const res = await fetch(
        "https://cms.exploratoursperu.com/wp-json/contact-form-7/v1/contact-forms/44/feedback",
        {
          method: "POST",
          body: formData,
        }
      );

      const data = await res.json();

      if (data.status === "mail_sent") {
        alert("Mensaje enviado correctamente");
        form.reset();
      } else {
        alert(data.message);
      }

    } catch (error) {
      console.error(error);
      alert("Error enviando el mensaje");
    } finally {
      // Usar finally asegura que el loader se quite siempre, incluso si hay error
      loader.classList.remove("active");
      submitBtn.disabled = false;
    }
  });

});
</script>