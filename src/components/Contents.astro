---
const pathname = Astro.url.pathname;
const dondition = pathname === "/en/" || pathname === "/en";
---

{
  dondition ?
  <div class="container py-16 mx-auto lg:py-20">
  <div class="mb-10 md:mx-auto sm:text-center lg:max-w-2xl md:mb-12">
    <div>
      <h3 class="text-center text-red text-lg normal-case"><i class="fa-solid fa-briefcase"></i> Travel Agency in Cusco</h3>
    </div>
    <h2 class="max-w-lg mb-6 font-sans text-3xl font-bold leading-none tracking-tight text-gray-900 sm:text-4xl md:mx-auto">
      <!-- <span class="relative inline-block">
        <svg viewBox="0 0 52 24" fill="currentColor" class="absolute top-0 left-0 z-0 hidden w-32 -mt-8 -ml-20 text-blue-gray-100 lg:w-32 lg:-ml-28 lg:-mt-10 sm:block">
          <defs>
            <pattern id="3071a3ad-db4a-4cbe-ac9a-47850b69e4b7" x="0" y="0" width=".135" height=".30">
              <circle cx="1" cy="1" r=".7"></circle>
            </pattern>
          </defs>
          <rect fill="url(#3071a3ad-db4a-4cbe-ac9a-47850b69e4b7)" width="52" height="24"></rect>
        </svg>
      </span> -->
      Discover unique experiences in Cusco
    </h2>
    <p class="text-base text-gray-700 md:text-lg">
      Turn every trip into an unforgettable adventure by exploring the best of Peru with local experts.
    </p>
  </div>
  <div class="grid gap-8 lg:grid-cols-2 sm:mx-auto">
    <div class="flex flex-col justify-center">
      <div class="flex">
        <div class="mr-4">
          <div class="flex items-center justify-center w-10 h-10 mb-3 rounded-full bg-yellow/50">
            <svg class="w-8 h-8 text-deep-purple-accent-400" stroke="currentColor" viewBox="0 0 52 52">
              <polygon stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" points="29 13 14 29 25 29 23 39 38 23 27 23"></polygon>
            </svg>
          </div>
        </div>
        <div>
          <h3 class="mb-2 font-semibold leading-5">
            Personalized attention
          </h3>
          <p class="text-sm text-gray-900">
            We create tailor-made itineraries, adapting to your interests, times and travel style so you can enjoy every moment without worries.
          </p>
          <hr class="w-full my-6 border-gray-300" />
        </div>
      </div>
      <div class="flex">
        <div class="mr-4">
          <div class="flex items-center justify-center w-10 h-10 mb-3 rounded-full bg-yellow/50">
            <svg class="w-8 h-8 text-deep-purple-accent-400" stroke="currentColor" viewBox="0 0 52 52">
              <polygon stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" points="29 13 14 29 25 29 23 39 38 23 27 23"></polygon>
            </svg>
          </div>
        </div>
        <div>
          <h3 class="mb-2 font-semibold leading-5">Authentic experiences</h3>
          <p class="text-sm text-gray-900">
            Connect with the essence of Cusco through culture, history and nature, guided by local experts who enrich each journey.
          </p>
          <hr class="w-full my-6 border-gray-300" />
        </div>
      </div>
      <div class="flex">
        <div class="mr-4">
          <div class="flex items-center justify-center w-10 h-10 mb-3 rounded-full bg-yellow/50">
            <svg class="w-8 h-8 text-deep-purple-accent-400" stroke="currentColor" viewBox="0 0 52 52">
              <polygon stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" points="29 13 14 29 25 29 23 39 38 23 27 23"></polygon>
            </svg>
          </div>
        </div>
        <div>
          <h3 class="mb-2 font-semibold leading-5">Smooth Travel Experience</h3>
          <p class="text-sm text-gray-900">
            We handle all the logistics so you can focus on enjoying your trip, with safety, organization and assistance at every stage of your journey.
          </p>
        </div>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-5">
      <img class="object-cover w-full h-56 col-span-2 rounded-radio shadow-lg" src="https://cms.exploratoursperu.com/wp-content/uploads/bann.webp" alt="" />
      <img class="object-cover w-full h-48 rounded-radio shadow-lg" src="https://cms.exploratoursperu.com/wp-content/uploads/bann-1.jpg" alt="" />
      <img class="object-cover w-full h-48 rounded-radio shadow-lg" src="https://cms.exploratoursperu.com/wp-content/uploads/bann-2.png" alt="" />
    </div>
  </div>
</div>
